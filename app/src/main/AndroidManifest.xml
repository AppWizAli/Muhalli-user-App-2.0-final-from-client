<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:name=".MuhalliApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:testOnly="false"
        android:theme="@style/Theme.MuhalliNewUserApp20"
        android:usesCleartextTraffic="true">

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="@string/google_maps_key" />

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_stat_muhalli_notification" />

        <activity
            android:name=".Ui.LanguageSelectionActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.ChooseAppActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.ActivityOnboarding"
            android:exported="false" />

        <activity
            android:name=".supplier.Ui.ActivitySupplierOnboarding"
            android:exported="false" />

        <activity
            android:name=".supplier.Ui.SupplierLoginActivity"
            android:exported="false" />

        <activity
            android:name=".supplier.Ui.SupplierRegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".supplier.Ui.SupplierMainActivity"
            android:exported="false" />

        <activity
            android:name=".supplier.Ui.SupplierAddProductActivity"
            android:exported="false" />

        <activity
            android:name=".supplier.Ui.SupplierMessagesActivity"
            android:exported="false" />

        <activity
            android:name=".supplier.Ui.SupplierNotificationsActivity"
            android:exported="false" />

        <activity
            android:name=".supplier.Ui.SupplierChatConversationActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".supplier.Ui.SupplierInventoryManagementActivity"
            android:exported="false" />

        <activity
            android:name=".supplier.Ui.SupplierEditProfileActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".supplier.Ui.SupplierOrderStatusActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.ActivitySplash"
            android:exported="true"
            android:theme="@style/Theme.MuhalliNewUserApp20.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".Ui.LoginActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.OtpVerificationActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".Ui.SupplierDetailsActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.MapActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".Ui.NotificationsActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.ReferralActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.CartActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.ChatConversationActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".Ui.ChatsActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.AccountDetailsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".Ui.AboutAppActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.OrderDetailsActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.OrderSuccessActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.CheckoutReviewActivity"
            android:exported="false" />

        <activity
            android:name=".Ui.CheckoutAddressActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".Ui.SuppliersActivity"
            android:exported="false" />

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <service
            android:name=".notifications.AppMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>

</manifest>
