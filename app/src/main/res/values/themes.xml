<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MuhalliNewUserApp20" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/primary</item>
        <item name="colorSecondaryVariant">@color/primary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="fontFamily">@font/ibm_plex_sans_arabic_regular</item>
        <item name="android:fontFamily">@font/ibm_plex_sans_arabic_regular</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Muhalli.Headline</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Muhalli.Headline</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.Muhalli.Headline</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Muhalli.Headline</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Muhalli.Headline</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.Muhalli.Headline</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.Muhalli.Body</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Muhalli.Body</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.Muhalli.Body</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.Muhalli.Label</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.Muhalli.Label</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.Muhalli.Label</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:navigationBarColor">@color/bg_light</item>
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.MuhalliNewUserApp20" parent="Base.Theme.MuhalliNewUserApp20" />

    <style name="Theme.MuhalliNewUserApp20.Splash" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="android:statusBarColor">@color/bg_light</item>
        <item name="android:navigationBarColor">@color/bg_light</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
</resources>
