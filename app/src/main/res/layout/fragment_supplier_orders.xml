<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/supplier_orders_title"
        android:textColor="@color/text_dark"
        android:textSize="28sp"
                android:fontFamily="@font/lama_sans_medium"
        android:textStyle="bold" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipOrdersAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_supplier_pill_selected"
                android:gravity="center"
                android:minWidth="48dp"
                android:paddingHorizontal="14dp"
                android:text="@string/supplier_all"
                android:textColor="@android:color/white"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipOrdersPending"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_supplier_pill_default"
                android:gravity="center"
                android:minWidth="68dp"
                android:paddingHorizontal="14dp"
                android:text="@string/supplier_pending"
                android:textColor="@color/supplier_text_secondary" />

            <TextView
                android:id="@+id/chipOrdersConfirmed"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_supplier_pill_default"
                android:gravity="center"
                android:minWidth="74dp"
                android:paddingHorizontal="14dp"
                android:text="@string/supplier_confirmed"
                android:textColor="@color/supplier_text_secondary" />

            <TextView
                android:id="@+id/chipOrdersShipped"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_supplier_pill_default"
                android:gravity="center"
                android:minWidth="68dp"
                android:paddingHorizontal="14dp"
                android:text="@string/supplier_shipped"
                android:textColor="@color/supplier_text_secondary" />

            <TextView
                android:id="@+id/chipOrdersDelivered"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_supplier_pill_default"
                android:gravity="center"
                android:minWidth="72dp"
                android:paddingHorizontal="14dp"
                android:text="@string/supplier_delivered"
                android:textColor="@color/supplier_text_secondary" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:fadeScrollbars="false"
        android:paddingBottom="20dp"
        android:scrollbarStyle="insideInset"
        android:scrollbars="vertical" />

    <LinearLayout
        android:id="@+id/layoutOrdersSkeleton"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <include layout="@layout/item_inventory_skeleton" />
        <include layout="@layout/item_inventory_skeleton" />
        <include layout="@layout/item_inventory_skeleton" />
        <include layout="@layout/item_inventory_skeleton" />
    </LinearLayout>
</LinearLayout>

