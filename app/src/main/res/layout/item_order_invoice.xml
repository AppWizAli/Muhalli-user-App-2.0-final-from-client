<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="12dp">

    <TextView
        android:id="@+id/tvInvoiceLineTotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/primary"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvInvoiceQuantity"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:background="@drawable/bg_quantity_selector"
        android:gravity="center"
        android:minWidth="54dp"
        android:paddingHorizontal="12dp"
        android:textColor="@color/text_dark"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvInvoiceProductName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:textColor="@color/text_dark"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintLeft_toRightOf="@id/tvInvoiceLineTotal"
        app:layout_constraintRight_toLeftOf="@id/tvInvoiceQuantity"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvInvoiceMeta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="12dp"
        android:textColor="@color/text_grey"
        android:textSize="12sp"
        app:layout_constraintLeft_toRightOf="@id/tvInvoiceLineTotal"
        app:layout_constraintRight_toLeftOf="@id/tvInvoiceQuantity"
        app:layout_constraintTop_toBottomOf="@id/tvInvoiceProductName" />

</androidx.constraintlayout.widget.ConstraintLayout>
