<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:fadeScrollbars="false"
    android:fillViewport="true"
    android:scrollbarStyle="insideInset"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_arrow_back_24"
                app:tint="@color/text_dark" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/supplier_edit_profile_title"
                android:textColor="@color/text_dark"
                android:textSize="24sp"
                android:fontFamily="@font/lama_sans_medium"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvAvatar"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:background="@drawable/bg_supplier_avatar"
                android:gravity="center"
                android:text="F"
                android:textColor="@android:color/white"
                android:textSize="30sp"
                android:fontFamily="@font/lama_sans_medium"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:layout_gravity="start"
                android:text="@string/supplier_business_name"
                android:textColor="@color/text_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etBusinessName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext"
                android:paddingHorizontal="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_gravity="start"
                android:text="@string/supplier_owner_name"
                android:textColor="@color/text_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etOwnerName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext"
                android:paddingHorizontal="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_gravity="start"
                android:text="@string/supplier_phone_number"
                android:textColor="@color/text_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext"
                android:inputType="phone"
                android:paddingHorizontal="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_gravity="start"
                android:text="@string/city"
                android:textColor="@color/text_dark"
                android:textStyle="bold" />

            <AutoCompleteTextView
                android:id="@+id/etCity"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext"
                android:completionThreshold="1"
                android:paddingHorizontal="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_gravity="start"
                android:text="@string/supplier_business_address"
                android:textColor="@color/text_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etAddress"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext"
                android:focusable="false"
                android:gravity="top|start"
                android:inputType="none"
                android:padding="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChooseLocation"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:text="@string/supplier_choose_location_on_map"
                android:textAllCaps="false"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_location_on_24" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_gravity="start"
                android:text="@string/supplier_minimum_order_quantity"
                android:textColor="@color/text_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etMinimumOrderQuantity"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext"
                android:inputType="number"
                android:paddingHorizontal="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_gravity="start"
                android:text="@string/supplier_minimum_order_amount_pkr"
                android:textColor="@color/text_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etMinimumOrderAmount"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext"
                android:inputType="number"
                android:paddingHorizontal="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="28dp"
                android:text="@string/save_changes"
                android:textAllCaps="false"
                app:cornerRadius="16dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

