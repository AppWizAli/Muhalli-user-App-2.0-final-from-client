<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_arrow_back_24"
            app:tint="@color/text_dark" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/supplier_messages_title"
            android:textColor="@color/text_dark"
            android:textSize="24sp"
                android:fontFamily="@font/lama_sans_medium"
            android:textStyle="bold" />
    </LinearLayout>

    <EditText
        android:id="@+id/etSearchConversations"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/bg_edittext"
        android:drawableStart="@drawable/ic_search_24"
        android:drawablePadding="10dp"
        android:hint="@string/supplier_search_conversations"
        android:paddingHorizontal="14dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvConversations"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:fadeScrollbars="false"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp"
        android:scrollbarStyle="insideInset"
        android:scrollbars="vertical" />
</LinearLayout>
