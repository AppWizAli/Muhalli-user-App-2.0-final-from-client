<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

<androidx.core.widget.NestedScrollView
    android:id="@+id/scrollAddProduct"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fadeScrollbars="false"
    android:fillViewport="true"
    android:paddingBottom="92dp"
    android:scrollbarStyle="insideInset"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_arrow_back_24"
                app:tint="@color/text_dark" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAddProductTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/supplier_add_product"
                    android:textColor="@color/text_dark"
                    android:textSize="22sp"
                android:fontFamily="@font/lama_sans_medium"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvStepLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/supplier_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <LinearLayout
            android:id="@+id/layoutStepCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/supplier_select_category"
                android:textColor="@color/text_dark"
                android:textSize="22sp"
                android:fontFamily="@font/lama_sans_medium"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/supplier_select_category_description"
                android:textColor="@color/supplier_text_secondary"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etSearchCategories"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_edittext"
                android:drawableStart="@drawable/ic_search_24"
                android:drawablePadding="10dp"
                android:hint="@string/supplier_search_categories_and_products"
                android:paddingHorizontal="14dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCatalogProductSearchResults"
                android:layout_width="match_parent"
                android:layout_height="420dp"
                android:layout_marginTop="14dp"
                android:nestedScrollingEnabled="true"
                android:overScrollMode="ifContentScrolls"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutCatalogProductSearchLoading"
                android:layout_width="match_parent"
                android:layout_height="420dp"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="32dp"
                    android:layout_height="32dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/supplier_catalog_search_loading"
                    android:textColor="@color/supplier_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutCategorySkeleton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <include layout="@layout/item_category_skeleton" />
                    <include layout="@layout/item_category_skeleton" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <include layout="@layout/item_category_skeleton" />
                    <include layout="@layout/item_category_skeleton" />
                </LinearLayout>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategories"
                android:layout_width="match_parent"
                android:layout_height="420dp"
                android:layout_marginTop="14dp"
                android:nestedScrollingEnabled="true"
                android:overScrollMode="ifContentScrolls" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNextCategory"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="16dp"
                android:text="@string/supplier_next_choose_product"
                android:textAllCaps="false"
                android:visibility="gone"
                app:cornerRadius="16dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutStepProduct"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvSelectedCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_supplier_pill_default"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:textColor="@color/primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvChangeCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="@string/supplier_change"
                    android:textColor="@color/primary"
                    android:textStyle="bold" />
            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/supplier_catalog_flow_note"
                android:textColor="@color/supplier_text_secondary"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/etSearchCatalog"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_edittext"
                android:drawableStart="@drawable/ic_search_24"
                android:drawablePadding="10dp"
                android:hint="@string/supplier_search_catalog"
                android:paddingHorizontal="14dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCatalogProducts"
                android:layout_width="match_parent"
                android:layout_height="420dp"
                android:layout_marginTop="14dp"
                android:nestedScrollingEnabled="true"
                android:overScrollMode="ifContentScrolls" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNextProduct"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="16dp"
                android:text="@string/supplier_next_set_pricing"
                android:textAllCaps="false"
                android:visibility="gone"
                app:cornerRadius="16dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutStepPricing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/supplier_pricing_stock"
                android:textColor="@color/text_dark"
                android:textSize="22sp"
                android:fontFamily="@font/lama_sans_medium"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_supplier_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <FrameLayout
                    android:layout_width="54dp"
                    android:layout_height="54dp">

                    <ImageView
                        android:id="@+id/ivSelectedProductImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_supplier_thumb"
                        android:padding="10dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_image_24" />

                    <TextView
                        android:id="@+id/tvSelectedProductThumb"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textColor="@color/text_dark"
                        android:textSize="18sp"
                android:fontFamily="@font/lama_sans_medium"
                        android:textStyle="bold" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvSelectedProductName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSelectedProductMeta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/supplier_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/supplier_price_per_unit"
                android:textColor="@color/text_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etPrice"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext"
                android:hint="@string/supplier_enter_price"
                android:inputType="number"
                android:paddingHorizontal="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/supplier_offer_price_optional"
                android:textColor="@color/text_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etOfferPrice"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext"
                android:hint="@string/supplier_offer_price_optional_hint"
                android:inputType="number"
                android:paddingHorizontal="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/supplier_offer_max_quantity_optional"
                android:textColor="@color/text_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etOfferMaxQuantity"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext"
                android:hint="@string/supplier_offer_max_quantity_optional_hint"
                android:inputType="number"
                android:paddingHorizontal="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/supplier_stock_quantity"
                android:textColor="@color/text_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etStock"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext"
                android:hint="@string/supplier_enter_stock_quantity"
                android:inputType="number"
                android:paddingHorizontal="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/supplier_delivery_days"
                android:textColor="@color/text_dark"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etDeliveryDays"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_edittext"
                android:hint="@string/supplier_enter_delivery_days"
                android:paddingHorizontal="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/supplier_product_image"
                android:textColor="@color/text_dark"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSelectedImageStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/supplier_product_image_helper"
                android:textColor="@color/supplier_text_secondary"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChooseProductImage"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:text="@string/supplier_upload_product_image"
                android:textAllCaps="false"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_image_24" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_supplier_card"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/supplier_available_for_orders"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/supplier_available_for_orders_desc"
                        android:textColor="@color/supplier_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchAvailable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:checked="true" />
            </RelativeLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveProduct"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="24dp"
                android:text="@string/supplier_save_to_store"
                android:textAllCaps="false"
                app:cornerRadius="16dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStickyNext"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="18dp"
        android:text="@string/supplier_next_choose_product"
        android:textAllCaps="false"
        app:cornerRadius="16dp" />
</FrameLayout>
