<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:orientation="vertical"
    android:padding="14dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvThumbInitial"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_supplier_thumb"
                android:gravity="center"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:fontFamily="@font/lama_sans_medium"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvProductName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/supplier_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUpdate"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:minWidth="0dp"
            android:paddingHorizontal="14dp"
            android:text="@string/supplier_update"
            android:textAllCaps="false"
            android:textSize="12sp"
            app:cornerRadius="12dp" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivMinus"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_supplier_card"
            android:clickable="true"
            android:focusable="true"
            android:padding="10dp"
            android:src="@drawable/ic_remove_24" />

        <TextView
            android:id="@+id/tvStockCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:textColor="@color/text_dark"
            android:textSize="20sp"
                android:fontFamily="@font/lama_sans_medium"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivPlus"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_supplier_fab"
            android:clickable="true"
            android:focusable="true"
            android:padding="10dp"
            android:src="@drawable/ic_add_24"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/tvUnit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:textColor="@color/supplier_text_secondary"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>

