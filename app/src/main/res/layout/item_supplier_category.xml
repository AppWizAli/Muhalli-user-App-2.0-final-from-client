<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    android:background="@drawable/bg_supplier_card"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/tvCategoryInitial"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_supplier_thumb"
        android:gravity="center"
        android:textColor="@color/text_dark"
        android:textSize="18sp"
                android:fontFamily="@font/lama_sans_medium"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvCategoryName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:textColor="@color/text_dark"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvCategoryCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_supplier_pill_default"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:textColor="@color/primary"
        android:textSize="11sp"
        android:textStyle="bold" />
</LinearLayout>
